# Azure OpenAI (Azure AI Foundry) — shared key, separate deployment configs
AZURE_OPENAI_API_KEY=

# Whisper (transcription)
AZURE_OPENAI_WHISPER_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_WHISPER_API_VERSION=2024-06-01
AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper

# GPT (vision + report synthesis)
AZURE_OPENAI_GPT_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_GPT_API_VERSION=2024-12-01-preview
AZURE_OPENAI_GPT_DEPLOYMENT=gpt-5.4

# App
LOG_LEVEL=INFO
STORAGE_DIR=./var
TEMPLATES_DIR=../data/4 Report Templates
GLOSSARY_PATH=../data/6 Industrial Crane Dictionary/Konecranes_Crane_Dictionary_EN_FI.pdf
MAX_UPLOAD_MB=200
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
