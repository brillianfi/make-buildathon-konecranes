# Azure OpenAI (Azure AI Foundry) — used for BOTH Whisper transcription and GPT vision/synthesis
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper
AZURE_OPENAI_GPT_DEPLOYMENT=gpt-4o

# App
LOG_LEVEL=INFO
STORAGE_DIR=./var
TEMPLATES_DIR=../data/4 Report Templates
GLOSSARY_PATH=../data/6 Industrial Crane Dictionary/Konecranes_Crane_Dictionary_EN_FI.pdf
MAX_UPLOAD_MB=200
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
